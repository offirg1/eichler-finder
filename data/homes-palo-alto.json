{
  "meta": {
    "description": "Per-address Eichler model data for Palo Alto, transcribed from public records. Currently covers the Greenmeadow National Register Historic District (Units I & II).",
    "source": "National Register of Historic Places Registration Form, Greenmeadow, Santa Clara County, CA (listed 2005-07-28). Inventory: 'List of Street Addresses and Changes', section 7. Public federal document.",
    "sourceUrl": "https://npgallery.nps.gov/GetAsset/9045e8b8-559b-43ce-8546-12bb24f49aab",
    "city": "Palo Alto",
    "transcribed": "2026-07-06",
    "notes": "Model numbers 1-6 are the six Jones & Emmons designs offered in Greenmeadow (1954-55). 'model: null' means the NRHP surveyors were unable to determine the original model (usually due to remodeling). status C = contributor to the historic district, NC = non-contributor. The Greenmeadow Community Center complex at 303 Parkside Drive is excluded (not a residence).",
    "homeFields": ["houseNumber", "street", "model", "status"]
  },
  "tracts": {
    "greenmeadow": {
      "models": {
        "1": { "name": "Greenmeadow Model 1", "summary": "Garage and bedroom wing flank a living/dining area set toward the back; the bedroom wing is recessed from the street. Two dead-level flat roofs (8 ft in front, 10 ft in back) with clerestory windows in the gap lighting the kitchen/dining area. The garage roof overhang shelters the recessed front entry; beams run front to back." },
        "2": { "name": "Greenmeadow Model 2", "summary": "An 8-ft dead-level flat roof across the front with a 10-ft dead-level roof over the living room on the garage side. Clerestory (transom) windows between the two roof heights light the back of the house. Garage on one side and a corner post on the other flank the front entry; beams run front to back." },
        "3": { "name": "Greenmeadow Model 3", "summary": "Articulated-pitch roof starting with a shed roof over the garage (8 ft rising to 10 ft, beams running side to side), the high end pointing to the house's center. Entry on the garage side at the center of the facade with one small eye-level vertical window; a camouflaged heater-room door is visible from the front. Sideways clerestory windows between the roof pitches." },
        "4": { "name": "Greenmeadow Model 4", "summary": "Garage on one side, bedroom wing on the other, under a single folded-pitch roof — flat on both sides with a slight pitch at the center. A wide, shallow central recessed entry has eye-level kitchen windows in the center topped by trapezoidal windows up to the roofline, with the front door toward the bedroom wing. Garage-side beams run side to side." },
        "5": { "name": "Greenmeadow Model 5", "summary": "The most common Greenmeadow model. A single low center-pitched gable roof runs the entire width of the front. Garage on one side, a concrete-block wall on the other, with the entrance on the block-wall side. Trapezoidal clerestory glass fills the triangular gaps up to the roofline." },
        "6": { "name": "Greenmeadow Model 6", "summary": "Garage and bedroom wing flank a central entry recessed about four feet, with eye-level windows topped by trapezoidal glass to the roofline. Front door sits toward the bedroom wing with a strip side-window on the garage side. A single shed roof (8 ft at the garage rising to 10 ft at the bedroom wing) covers the garage and center; the bedroom wing itself has a flat roof; beams run front to back." }
      },
